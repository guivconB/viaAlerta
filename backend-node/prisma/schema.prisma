generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id                   String          @id @default(uuid())
  name                 String
  email                String          @unique
  password             String
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime        @default(now())
  reflexTests          ReflexTest[]
  trafficReports       TrafficReport[]
}

model ReflexTest {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  reactionTimeMs Int
  status         String   // EXCELENTE, BOM, ALERTA, PERIGO_FADIGA_EXTREMA
  createdAt      DateTime @default(now())

  @@index([userId])
}

model TrafficReport {
  id                   String   @id @default(uuid())
  authorId             String
  author               User     @relation(fields: [authorId], references: [id])
  problemType          String   // BURACO, SEMAFORO_QUEBRADO, ILUMINACAO_DEFICIENTE, ACIDENTE, OUTRO
  shortDescription     String   @db.VarChar(150)
  neighborhoodOrStreet String
  createdAt            DateTime @default(now())

  @@index([authorId])
}
